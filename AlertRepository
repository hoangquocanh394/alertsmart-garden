package com.smartgarden.repository;

import com.smartgarden.model.Alert;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;

import java.util.List;

@Repository
public interface AlertRepository extends JpaRepository<Alert, Long> {

    List<Alert> findByDeviceIdOrderByCreatedAtDesc(String deviceId);

    List<Alert> findByDeviceIdAndAcknowledgedFalseOrderByCreatedAtDesc(String deviceId);
    
}
