package com.smartgarden.repository;

import com.smartgarden.model.SensorData;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;
import org.springframework.data.jpa.repository.Query;
import java.util.List;
import java.util.Optional;

@Repository
public interface SensorDataRepository extends JpaRepository<SensorData, Long> {

    /** Latest record for a device */
    Optional<SensorData> findTopByDeviceIdOrderByRecordedAtDesc(String deviceId);

    /** Last N records for history chart */
    List<SensorData> findTop20ByDeviceIdOrderByRecordedAtDesc(String deviceId);

}
