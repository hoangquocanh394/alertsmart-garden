package com.smartgarden.model;

import jakarta.persistence.*;
import lombok.Data;
import java.time.LocalDateTime;

@Entity
@Table(name = "alert")                    // <-- thêm dòng này
@Inheritance(strategy = InheritanceType.SINGLE_TABLE)   // <-- đổi từ TABLE_PER_CLASS sang SINGLE_TABLE
@DiscriminatorColumn(name = "alert_type", discriminatorType = DiscriminatorType.STRING)  // <-- thêm discriminator
@Data
public abstract class Alert {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @Column(name = "device_id", nullable = false)
    private String deviceId;

    @Column(nullable = false)
    private String message;

    @Column(nullable = false)
    private boolean acknowledged = false;

    @Column(name = "created_at")
    private LocalDateTime createdAt;

    @PrePersist
    public void prePersist() {
        this.createdAt = LocalDateTime.now();
    }

    public abstract String getAlertType();
    public abstract boolean isCritical();
}
